{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "milier-mtproxy-launcher",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-11",
  "routes": [
    {
      "pattern": "mtproxy.813099.xyz",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
